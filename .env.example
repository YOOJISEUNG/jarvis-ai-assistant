# 실제 사용 시 이 파일을 .env로 복사 후 값 입력

# === 필수 ===
ANTHROPIC_API_KEY=sk-ant-(발급받으신 anthropic key 입력)
ANTHROPIC_MODEL=claude-sonnet-4-6

USER_NAME=YourName
TTS_VOICE=ko-KR-HyunsuNeural

# === 서버 ===
SERVER_PORT=3000

OPENWEATHER_API_KEY=(직접 발급 받으신 OpenWeather key 넣으시면 됩니다)

# === 고급 옵션 ===
BROWSER_HEADLESS=false
MEMORY_ENABLED=true
MEMORY_TOP_K=3
